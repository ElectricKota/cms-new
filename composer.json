{
  "name": "electrickota/cms-new",
  "description": "Modern Nette CMS foundation with admin and Latte frontend.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.4 || ^8.5",
    "ext-gd": "*",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "latte/latte": "^3.0",
    "nette/application": "^3.2",
    "nette/bootstrap": "^3.2",
    "nette/caching": "^3.2",
    "nette/database": "^3.2",
    "nette/di": "^3.2",
    "nette/forms": "^3.2",
    "nette/http": "^3.2",
    "nette/mail": "^4.0",
    "nette/robot-loader": "^4.0",
    "nette/security": "^3.2",
    "nette/utils": "^4.0",
    "ramsey/uuid": "^4.7",
    "tracy/tracy": "^2.10"
  },
  "require-dev": {
    "efabrica/phpstan-latte": "^0.20",
    "nette/tester": "^2.5",
    "phpstan/phpstan": "^2.1",
    "squizlabs/php_codesniffer": "^3.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "analyse": "phpstan analyse",
    "latte-lint": "latte-lint app",
    "cs": "phpcs app --standard=PSR12",
    "test": "tester tests"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
