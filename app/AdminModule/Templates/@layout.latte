<!doctype html>
<html lang="cs">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{ifset title}{include title|stripHtml} | {/ifset}CMS</title>
    {$vite->tags('resources/js/admin.js')|noescape}
</head>
<body class="admin-shell">
    <aside class="admin-nav">
        <strong class="admin-brand">
            <span class="nav-icon nav-icon-brand" aria-hidden="true"></span>
            <span class="admin-brand__label">
                <span>CMS</span>
                <small>by Michal Kotek</small>
            </span>
        </strong>
        <div class="admin-user" data-tooltip="{$currentUserName}" title="{$currentUserName}">
            <span class="nav-icon nav-icon-user" aria-hidden="true"></span>
            <div class="admin-user__text">
                <span>Přihlášen</span>
                <strong>{$currentUserName}</strong>
                <small n:if="$currentUserEmail">{$currentUserEmail}</small>
                <small>{implode(', ', $currentUserRoles)}</small>
            </div>
        </div>
        <nav>
            <a n:href=":Front:Homepage:default" class="admin-nav-link admin-nav-external" data-tooltip="Zobrazit web" aria-label="Zobrazit web" title="Zobrazit web">
                <span class="nav-icon nav-icon-web" aria-hidden="true"></span>
                <span class="admin-nav-label">Zobrazit web</span>
            </a>
            <a n:foreach="$adminMenu as $item" n:href="$item['link']" class="admin-nav-link" data-tooltip="{$item['label']}" aria-label="{$item['label']}" title="{$item['label']}">
                <span class="nav-icon nav-icon-{$item['icon']}" aria-hidden="true"></span>
                <span class="admin-nav-label">{$item['label']}</span>
            </a>
            <a n:href="Sign:out" class="admin-nav-link" data-tooltip="Odhlásit" aria-label="Odhlásit" title="Odhlásit">
                <span class="nav-icon nav-icon-logout" aria-hidden="true"></span>
                <span class="admin-nav-label">Odhlásit</span>
            </a>
        </nav>
    </aside>
    <main class="admin-main">
        <div n:foreach="$flashes as $flash" class="flash">{$flash->message}</div>
        {include content}
    </main>
    <dialog class="confirm-dialog" data-delete-dialog>
        <form method="dialog" class="confirm-dialog__panel">
            <h2>Smazat fotku?</h2>
            <p data-delete-dialog-message>Opravdu chcete fotku smazat?</p>
            <div class="confirm-dialog__actions">
                <button type="button" class="button button-muted" data-delete-dialog-cancel>Ne</button>
                <button type="button" class="button button-danger" data-delete-dialog-confirm>Ano</button>
            </div>
        </form>
    </dialog>
</body>
</html>
