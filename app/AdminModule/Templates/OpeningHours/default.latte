{block title}Otevírací doba{/block}
{block content}
<h1>Otevírací doba</h1>
{control openingForm}
<table>
    <tr><th>Text od</th><th>Text do</th><th>Čas</th><th>Poznámka</th><th></th></tr>
    <tr n:foreach="$items as $item">
        <td>{$item->label_from}</td>
        <td>{$item->label_to}</td>
        <td>{$item->time_from} - {$item->time_to}</td>
        <td>{$item->note}</td>
        <td class="actions"><a n:href="delete $item->id">Smazat</a></td>
    </tr>
</table>
